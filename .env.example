APP_NAME=Circuit Tablet API
APP_ENV=development
APP_HOST=127.0.0.1
APP_PORT=8000
LIBRARY_ROOT=/Users/jamesjohnson/Desktop/tablet/data/library
INDEX_DB_PATH=/Users/jamesjohnson/Desktop/tablet/data/index/library.db
MAX_SNIPPET_CHARS=1200
MAX_RESULTS=10
RETRIEVAL_WINDOW=1
DEFAULT_CHAT_LIMIT=6
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5:1.5b
OLLAMA_VISION_MODEL=qwen2.5vl:3b
RUNTIME_SETTINGS_PATH=/Users/jamesjohnson/Desktop/tablet/data/index/runtime_settings.json
CAPTURES_DIR=/Users/jamesjohnson/Desktop/tablet/data/captures
TTS_OUTPUT_DIR=/Users/jamesjohnson/Desktop/tablet/data/tts
PIPER_BINARY=piper
PIPER_MODEL_PATH=
WHISPER_MODEL_SIZE=base
CAMERA_ANALYZE_INTERVAL_SECONDS=4
# Later, point these at your SSD, for example:
# LIBRARY_ROOT=/media/ssd/library
# INDEX_DB_PATH=/media/ssd/index/library.db
